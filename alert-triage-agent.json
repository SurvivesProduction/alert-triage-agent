      "webhookId": "e3809830-2cfd-4980-a55c-b8c923787f7c"
    },
    {
      "parameters": {
        "resource": "text",
        "operation": "message",
        "modelId": {
          "__rl": true,
          "mode": "id",
          "value": "claude-haiku-4-5"
        },
        "messages": {
          "values": [
            {
              "content": "={{ JSON.stringify($json.body) }}",
              "role": "user"
            }
          ]
        },
        "simplify": true,
        "options": {
          "system": "You triage production incident alerts. Given an alert's service, environment, message, and error_rate, respond with strict JSON: {\"severity\": \"noise\"|\"real_issue\"|\"critical\", \"summary\": \"one sentence\", \"first_step\": \"one concrete suggested action\"}. \"noise\" = staging/non-production or zero impact. \"critical\" = production data loss, full outage, or security. \"real_issue\" = everything else that needs a human.",
          "maxTokens": 1024
        }
      },
      "id": "ai-0001-classify",
      "name": "Classify Alert (AI)",
      "type": "@n8n/n8n-nodes-langchain.anthropic",
      "typeVersion": 1,
      "position": [
        -1872,
        -320
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000
    },
    {
      "parameters": {
        "jsCode": "// Parse the AI node's reply into flat fields and merge with the original alert.\nconst item = $input.first().json;\nconst alert = $('Webhook').first().json.body;\n\nlet raw = '';\nif (Array.isArray(item.content) && item.content[0] && item.content[0].text) {\n  raw = item.content[0].text;\n} else if (typeof item.content === 'string') {\n  raw = item.content;\n} else if (item.text) {\n  raw = item.text;\n} else if (item.message && Array.isArray(item.message.content) && item.message.content[0]) {\n  raw = item.message.content[0].text || '';\n}\n\n// Strip markdown code fences (```json ... ``` or ``` ... ```) if present\nraw = raw.trim().replace(/^```(?:json)?\\s*/i, '').replace(/```\\s*$/i, '').trim();\n\nlet parsed;\ntry {\n  parsed = JSON.parse(raw);\n} catch (e) {\n  parsed = {\n    severity: 'real_issue',\n    summary: '[PARSE ERROR] Could not parse AI response as JSON: ' + String(raw).slice(0, 200),\n    first_step: 'Check the Classify Alert (AI) node output manually.'\n  };\n}\n\nreturn [{\n  json: {\n    ...alert,\n    severity: parsed.severity || 'real_issue',\n    summary: parsed.summary || '[MISSING] summary',\n    first_step: parsed.first_step || '[MISSING] first_step'\n  }\n}];"
      },
      "id": "ai-0002-parse",
      "name": "Parse AI Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1752,
        -320
      ]
    },
    {
      "parameters": {
        "jsCode": "// Enrich: merge classification output with a runbook link per service.\nconst item = $input.first().json;\n\n// Demo runbook links (this repo is a public template — swap these for your\n// team's real internal runbook URLs before using in production).\nconst runbooks = {\n  'orders-db': 'https://runbooks.survivesproduction.com/orders-db',\n  'checkout-api': 'https://runbooks.survivesproduction.com/checkout-api',\n  'batch-worker': 'https://runbooks.survivesproduction.com/batch-worker'\n};\n\nreturn [{\n  json: {\n    ...item,\n    runbook_url: runbooks[item.service] || 'https://runbooks.survivesproduction.com/default'\n  }\n}];"
      },
      "id": "04ac226e-3bb8-4f8c-8cab-77e9a4fbdbcd",
      "name": "Enrich",
      "type": "n8n-nodes-base.code",
