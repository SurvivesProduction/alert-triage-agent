        "jsCode": "// PLACEHOLDER — replace this node with a real OpenAI / Anthropic node.\n// See n8n_build_guide.md, Build Section 2, step 5, for the exact system prompt.\n// This stub returns a mock classification so the rest of the workflow can be\n// tested end-to-end before you wire up a real AI node + credential.\nconst alert = $input.first().json.body;\n\nlet severity = 'real_issue';\nif ((alert.environment || '').toLowerCase() === 'staging' || (alert.error_rate === 0)) {\n  severity = 'noise';\n} else if ((alert.severity_hint || '').toLowerCase() === 'critical') {\n  severity = 'critical';\n}\n\nreturn [{\n  json: {\n    ...alert,\n    severity,\n    summary: `[MOCK] ${alert.alert_name || 'Alert'} on ${alert.service || 'unknown service'}`,\n    first_step: '[MOCK] Replace this Code node with a real AI classification node.'\n  }\n}];"
